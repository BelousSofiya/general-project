    <part name="result" type="xsd:string"/>
  </message>

  <!-- Port Type -->
  <portType name="MongoDBSystemAPIPortType">
    <!-- Rocket Operations -->
    <operation name="CreateRocket">
      <input message="tns:CreateRocketRequest"/>
      <output message="tns:CreateRocketResponse"/>
    </operation>
    <operation name="GetRocketByExternalId">
      <input message="tns:GetRocketByExternalIdRequest"/>
